{
  "mcpServers": {
    "asset-generator": {
      "command": "npx",
      "args": ["tsx", "packages/asset-generator/src/index.ts"],
      "env": {
        "FAL_KEY": "${FAL_KEY}"
      }
    },
    "pdf-reader": {
      "command": "npx",
      "args": ["-y", "@sylphx/pdf-reader-mcp"]
    },
    "airtable": {
      "command": "npx",
      "args": ["-y", "airtable-mcp-server"],
      "env": {
        "AIRTABLE_API_KEY": "${AIRTABLE_API_KEY}"
      }
    }
  }
}
