{
  "name": "asset-generator",
  "projectType": "application",
  "sourceRoot": "packages/asset-generator/src",
  "tags": ["type:app", "lang:typescript"],
  "targets": {
    "build": {
      "command": "tsc",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true,
      "inputs": ["default"],
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "command": "tsx src/index.ts",
      "options": {
        "cwd": "packages/asset-generator"
      }
    },
    "start": {
      "command": "node dist/index.js",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "command": "eslint .",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true
    },
    "format": {
      "command": "prettier . --write",
      "options": {
        "cwd": "packages/asset-generator"
      }
    },
    "format:check": {
      "command": "prettier . --check",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true
    }
  }
}
