{
  "name": "asset-generator",
  "projectType": "application",
  "sourceRoot": "packages/asset-generator/src",
  "tags": ["type:app", "lang:python"],
  "targets": {
    "run": {
      "command": "uv run python -m asset-generator.main",
      "options": {
        "cwd": "packages/asset-generator/src"
      }
    },
    "install": {
      "command": "uv sync",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true,
      "inputs": ["{projectRoot}/pyproject.toml", "{projectRoot}/uv.lock"],
      "outputs": ["{projectRoot}/.venv"]
    },
    "lint": {
      "command": "uv run ruff check src/",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true,
      "inputs": ["default"],
      "dependsOn": ["install"]
    },
    "typecheck": {
      "command": "uv run pyright src/",
      "options": {
        "cwd": "packages/asset-generator"
      },
      "cache": true,
      "inputs": ["default"],
      "dependsOn": ["install"]
    }
  }
}
